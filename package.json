{
  "name": "aidos-ui",
  "version": "4.0.3",
  "description": "A simple UI framework",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "default": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "default": "./dist/jsx-dev-runtime.js"
    },
    "./vite-plugin-jss-debug": {
      "types": "./dist/vite-plugin-jss-debug.d.ts",
      "default": "./dist/vite-plugin-jss-debug.js"
    }
  },
  "scripts": {
    "embeddings": "node ./scripts/embeddings.js",
    "dev": "next dev",
    "publish:patch": "node ./scripts/publish.js --patch",
    "build": "next build",
    "build:lib": "rimraf ./dist && tsc --project tsconfig.build.json",
    "tsc": "tsc",
    "tsc:watch": "tsc --watch",
    "start": "next start",
    "lint": "next lint"
  },
  "type": "module",
  "author": "Gerard Moreno-Torres Bertran",
  "license": "ISC",
  "devDependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.5",
    "@types/node": "^25.0.10",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@xenova/transformers": "^2.17.2",
    "csstype": "^3.2.3",
    "dotenv": "^17.2.3",
    "install": "^0.13.0",
    "next": "latest",
    "npm": "^11.8.0",
    "openai": "^6.16.0",
    "prismjs": "^1.30.0",
    "process": "^0.11.10",
    "react-dom": "latest",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "unified": "^11.0.5"
  },
  "dependencies": {
    "@iconify-json/fa": "^1.2.2",
    "@iconify-json/fa-solid": "^1.2.2",
    "@iconify/react": "^6.0.2",
    "remark-gfm": "^4.0.1"
  },
  "peerDependencies": {
    "react": "latest"
  }
}
